# ── Required ─────────────────────────────────────────────────────────────────
# Seed phrase (mnemonic) of the deployer account.
# This account pays gas and is the origin of all on-chain transactions.
MNEMONIC=replace_with_your_local_deployer_mnemonic_never_commit_real_seed

# 32-byte hex pubkey of the treasury wallet (receives protocol fees).
TREASURY=0x<64 hex chars>

# ── Optional ──────────────────────────────────────────────────────────────────
# 32-byte hex pubkey for the program admin (defaults to deployer if omitted).
# ADMIN=0x<64 hex chars>

# Deploy salt suffix. Change this for every redeploy to avoid deterministic
# program address collisions.
# DEPLOY_VERSION=mainnet-2026-06-02

# Add the deployed DAO program as an admin on Oracle, BolaoCore, and FreebetLedger.
# This keeps the deployer/admin wallet in place and adds DAO governance rights.
# ADD_DAO_AS_ADMIN=true

# Optional comma-separated list of extra admin wallet pubkeys to add to all
# programs after deploy.
# EXTRA_ADMIN_PUBKEYS=0x<64 hex chars>,0x<64 hex chars>

# 32-byte hex pubkey of the rewards-backend hot wallet.
# This account is added as FreebetLedger admin so it can grant freebets.
# REWARDS_PUBKEY=0x<64 hex chars>

# 32-byte hex pubkey of the oracle-server's gateway wallet.
# Becomes an operator in BOTH Oracle and BolaoCore (needed for refresh_vara_price,
# register_match, force_finalize_result). Also authorized as an Oracle feeder.
# GATEWAY_PUBKEY=0x<64 hex chars>

# 32-byte hex pubkey to authorize as an Oracle feeder immediately after deploy.
# If GATEWAY_PUBKEY is set, that account is added as operator but not as feeder
# unless you ALSO set FEEDER_PUBKEY.
# FEEDER_PUBKEY=0x<64 hex chars>

# Paths to the compiled opt WASMs (default: release build output).
# Build WASMs first:
#   cd ../Oracle-Program   && cargo build --release
#   cd ../BolaoCore-Program && cargo build --release
# ORACLE_WASM=../Oracle-Program/target/wasm32-gear/release/oracle_program.opt.wasm
# BOLAO_WASM=../BolaoCore-Program/target/wasm32-gear/release/bolao_program.opt.wasm
# FREEBET_LEDGER_WASM=../FreebetLedger-Program/target/wasm32-gear/release/smartcup_freebet_ledger.opt.wasm
# DAO_WASM=../DAO-SmartCupLeague-Program/target/wasm32-gear/release/dao_program.opt.wasm

# Register the uploaded BolaoCore code_id in DAO so DAO can deploy future
# BolaoCore instances.
# REGISTER_BOLAO_CODE_IN_DAO=true

# Network to deploy to: "testnet" (default) or "mainnet"
# VARA_NETWORK=testnet
