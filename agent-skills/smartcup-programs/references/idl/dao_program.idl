/// All actions that can be proposed and voted on.
type ProposalKind = enum {
  /// Register a new tournament phase in BolaoCore.
  AddPhase: struct {
    name: str,
    start_time: u64,
    end_time: u64,
    /// Scoring weight: 1 = group stage, >1 = knockout rounds.
    points_weight: u32,
  },
  /// Register a new match in BolaoCore.
  AddMatch: struct {
    phase: str,
    home: str,
    away: str,
    kick_off: u64,
  },
  /// Grant or revoke oracle authority on BolaoCore.
  SetOracleAuthorized: struct {
    oracle: actor_id,
    authorized: bool,
  },
  /// Finalise the tournament podium on BolaoCore.
  FinalizePodium: struct {
    champion: str,
    runner_up: str,
    third_place: str,
  },
  /// Cancel an oracle-proposed result that is still inside the challenge window.
  /// Maps to BolaoCore::cancel_proposed_result(match_id).
  CancelMatchResult: struct {
    match_id: u64
  },
  /// Deploy a new BolaoCore program via the on-chain factory.
  /// `salt` must be unique per deployment to avoid deterministic address collisions.
  DeployBolao: struct {
    admin: actor_id,
    salt: vec u8,
    gas_limit: u64,
  },
  /// Change the minimum quorum (basis points, 10 000 = 100 %).
  SetQuorum: struct {
    new_quorum_bps: u16
  },
  /// Change the voting window duration (milliseconds).
  SetVotingPeriod: struct {
    new_voting_period: u64
  },
  /// Update the default BolaoCore program that governance dispatches to.
  SetDefaultBolao: struct {
    new_bolao: actor_id
  },
};

type VoteChoice = enum {
  Yes,
  No,
  Abstain,
};

/// Metadata for a BolaoCore instance deployed via the DAO factory.
type BolaoInstance = struct {
  program_id: actor_id,
  admin: actor_id,
  /// Block timestamp (ms) at which the program was created.
  deployed_at: u64,
};

type Proposal = struct {
  id: u64,
  proposer: actor_id,
  kind: ProposalKind,
  description: str,
  start_time: u64,
  end_time: u64,
  yes: u32,
  no: u32,
  abstain: u32,
  status: ProposalStatus,
  executed: bool,
};

type ProposalStatus = enum {
  Active,
  Defeated,
  Succeeded,
  Executed,
  /// Reserved for future time-lock extensions.
  Expired,
};

/// Read-only projection of DaoState returned by query_state().
type IoDaoState = struct {
  owner: actor_id,
  admins: vec actor_id,
  /// Default BolaoCore program that governance proposals dispatch to.
  bolao_program: actor_id,
  kyc_contract: opt actor_id,
  quorum_bps: u16,
  voting_period: u64,
  proposal_count: u64,
  /// True if a BolaoCore WASM code_id has been registered via register_bolao_code().
  bolao_code_registered: bool,
  /// Number of BolaoCore instances deployed via this DAO's factory.
  bolao_instance_count: u32,
};

constructor {
  /// Initialise the DAO.
  /// 
  /// `bolao_program` — The BolaoCore program that governance proposals will
  /// dispatch to by default. Can be updated later via set_bolao_program() or
  /// a SetDefaultBolao governance proposal.
  New : (bolao_program: actor_id);
};

service Service {
  AddAdmin : (new_admin: actor_id) -> null;
  /// Create a new governance proposal. Open to any caller.
  CreateProposal : (kind: ProposalKind, description: str) -> null;
  /// Deploy a new BolaoCore program immediately (no governance vote required).
  /// Owner-only. The factory records the new instance in bolao_instances.
  /// 
  /// `admin`     — Initial admin of the new BolaoCore instance.
  ///               Pass `exec::program_id()` to make this DAO the admin.
  /// `salt`      — Unique bytes used to derive the deterministic program address.
  /// `gas_limit` — Gas forwarded to the BolaoCore init handler.
  ///               Use DEFAULT_BOLAO_DEPLOY_GAS as a starting point.
  DeployBolao : (admin: actor_id, salt: vec u8, gas_limit: u64) -> null;
  /// Execute a proposal that has reached Succeeded status.
  /// Permissionless — any caller may trigger execution.
  /// 
  /// If the proposal is still Active, execution panics.
  /// If the proposal Defeated/Expired, its status is updated and the call returns.
  Execute : (proposal_id: u64) -> null;
  /// Compute and persist the final status of a proposal after voting ends.
  /// Permissionless — anyone can call this once `end_time` has passed.
  FinalizeProposal : (proposal_id: u64) -> null;
  ForceWithdrawVara : (to: actor_id, amount: u128) -> null;
  /// Register the WASM code_id (32-byte Blake2 hash) of the BolaoCore binary.
  /// Must be called before deploy_bolao() or executing a DeployBolao proposal.
  /// Owner-only.
  RegisterBolaoCode : (code_id: [u8, 32]) -> null;
  RemoveAdmin : (admin: actor_id) -> null;
  /// Update the default BolaoCore program that governance proposals dispatch to.
  /// Owner-only.
  SetBolaoProgram : (new_bolao: actor_id) -> null;
  /// Transfer ownership of this DAO to a new address.
  /// Owner-only. Single-step — use with care.
  SetOwner : (new_owner: actor_id) -> null;
  /// Cast a vote on an active proposal. Each address may vote once per proposal.
  Vote : (proposal_id: u64, choice: VoteChoice) -> null;
  WithdrawVara : (to: actor_id, amount: u128) -> null;
  /// Returns all BolaoCore instances deployed by this DAO's factory.
  query QueryBolaoInstances : () -> vec BolaoInstance;
  query QueryProposal : (proposal_id: u64) -> opt Proposal;
  query QueryProposals : () -> vec Proposal;
  query QueryState : () -> IoDaoState;
  query QueryVote : (proposal_id: u64, voter: actor_id) -> opt VoteChoice;

  events {
    /// A new governance proposal was created. (proposal_id, proposer)
    ProposalCreated: struct {
      u64,
      actor_id,
    };
    /// A vote was cast. (proposal_id, voter, choice)
    Voted: struct {
      u64,
      actor_id,
      VoteChoice,
    };
    /// Voting ended and the final status was computed. (proposal_id, status)
    ProposalFinalized: struct {
      u64,
      ProposalStatus,
    };
    /// A succeeded proposal was executed. (proposal_id)
    ProposalExecuted: u64;
    /// A governance command was dispatched to a BolaoCore program. (proposal_id)
    BolaoCallDispatched: u64;
    /// A new BolaoCore instance was deployed via the factory. (program_id, admin)
    BolaoDeployed: struct {
      actor_id,
      actor_id,
    };
    /// A BolaoCore WASM code_id was registered (no args — code is sensitive).
    BolaoCodeRegistered;
    /// A DAO governance parameter (quorum, voting period, or bolao_program) was updated.
    GovernanceParamUpdated;
    /// The DAO owner was changed. (new_owner)
    OwnerChanged: actor_id;
    /// An additional admin was added. (admin)
    AdminAdded: actor_id;
    /// An admin was removed. (admin)
    AdminRemoved: actor_id;
    /// Admin withdrew VARA held by this DAO. (to, amount)
    VaraWithdrawn: struct {
      actor_id,
      u128,
    };
    /// Owner emergency withdrawal of any VARA held by this DAO. (to, amount)
    ForceVaraWithdrawn: struct {
      actor_id,
      u128,
    };
  }
};

