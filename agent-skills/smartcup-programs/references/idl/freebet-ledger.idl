type FreebetLedgerInit = struct {
  admin: actor_id,
};

type Score = struct {
  home: u8,
  away: u8,
};

type PenaltyWinner = enum {
  Home,
  Away,
};

type FreebetGrant = struct {
  id: str,
  recipient: actor_id,
  amount: u128,
  reason: str,
  granted_at: u64,
};

constructor {
  New : (init: FreebetLedgerInit);
};

service FreebetLedger {
  AddAdmin : (new_admin: actor_id) -> null;
  AuthorizeBetProgram : (program_id: actor_id) -> null;
  ForceWithdrawVara : (to: actor_id, amount: u128) -> null;
  Grant : (to: actor_id, grant_id: str, reason: str) -> u128;
  RemoveAdmin : (admin: actor_id) -> null;
  ReturnFreebet : (user: actor_id, match_id: u64) -> u128;
  RevokeBetProgram : (program_id: actor_id) -> null;
  SpendFreebet : (bet_program_id: actor_id, match_id: u64, amount: u128, predicted_score: Score, predicted_penalty_winner: opt PenaltyWinner) -> u128;
  WithdrawSurplusVara : (to: actor_id, amount: u128) -> null;
  query Admin : () -> actor_id;
  query Admins : () -> vec actor_id;
  query BalanceOf : (user: actor_id) -> u128;
  query GetGrant : (grant_id: str) -> opt FreebetGrant;
  query GetPendingSpendCount : () -> u64;
  query IsBetProgramAuthorized : (program_id: actor_id) -> bool;
  query SurplusVara : () -> u128;
  query TotalLiability : () -> u128;

  events {
    AdminAdded: struct {
      admin: actor_id
    };
    AdminRemoved: struct {
      admin: actor_id
    };
    BetProgramAuthorized: struct {
      program_id: actor_id
    };
    BetProgramRevoked: struct {
      program_id: actor_id
    };
    FreebetGranted: struct {
      recipient: actor_id,
      amount: u128,
      balance: u128,
      grant_id: str,
      reason: str,
    };
    FreebetSpent: struct {
      user: actor_id,
      bet_program_id: actor_id,
      match_id: u64,
      amount: u128,
      remaining_balance: u128,
    };
    FreebetReturned: struct {
      user: actor_id,
      bet_program_id: actor_id,
      match_id: u64,
      amount: u128,
      balance: u128,
    };
    FreebetSpendFailed: struct {
      user: actor_id,
      bet_program_id: actor_id,
      match_id: u64,
      amount: u128,
      restored_balance: u128,
    };
    VaraWithdrawn: struct {
      to: actor_id,
      amount: u128,
    };
    ForceVaraWithdrawn: struct {
      to: actor_id,
      amount: u128,
    };
  }
};

