# Vara testnet Subsquid archive gateway
VARA_ARCHIVE_URL=https://v2.archive.subsquid.io/network/vara-testnet

# Vara testnet archive RPC — must be an archive node, not a live-only node
VARA_RPC_URL=wss://archive-rpc.vara.network

# RPC rate limit (requests/sec)
VARA_RPC_RATE_LIMIT=20

# BolaoCore program ID on testnet
VARA_PROGRAM_ID=0xf275cf3ec5799dcfa7077130685355066e1af381384eb91d7f8e20ad5e7bb28e

# Start indexing from this block
VARA_FROM_BLOCK=26000000

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bolao_indexer

# GraphQL API port
GQL_PORT=4350

# Frontend origin for CORS (Vite default)
FRONTEND_URL=http://localhost:5173

# Node environment (development | production)
NODE_ENV=development
